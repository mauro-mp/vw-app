# =============================================================================
# VW app — .env.example
# Copie para .env.local e preencha com valores reais.
# =============================================================================

# ---------------------------------------------------------------------------
# Banco de dados — PostgreSQL (único suportado)
# Dev local:      use o docker-compose.yml na raiz
# Produção:       Neon, Supabase, RDS, etc.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://vwapp:vwapp@localhost:5433/vwapp?schema=public"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# Mínimo 32 caracteres em dev; 64+ em produção. Gere com:
#   openssl rand -base64 48
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3001"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_BASE_URL="http://localhost:3001"

# ---------------------------------------------------------------------------
# Criptografia de segredos armazenados (ex.: client_secret de ApiClient)
# 64 hex chars = 32 bytes para AES-256. Gere com:
#   openssl rand -hex 32
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=""

# ---------------------------------------------------------------------------
# OAuth2 (emissão de tokens para consumidores da API, ex.: agent-hub)
# ---------------------------------------------------------------------------
# JWT assinado para access tokens. Gere com:
#   openssl rand -base64 48
OAUTH_JWT_SECRET=""
OAUTH_ACCESS_TOKEN_TTL_SECONDS="3600"

# ---------------------------------------------------------------------------
# Seed (opcional — credenciais do primeiro admin criado pelo seed)
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@fillmore.com.br"
SEED_ADMIN_PASSWORD="senha1234"
