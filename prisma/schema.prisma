generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String      @id @default(cuid())
  agentHubClientId String      @unique
  name             String
  slug             String      @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  apiClients       ApiClient[]
  employees        Employee[]
  units            Unit[]
}

model Unit {
  id                  String         @id @default(cuid())
  tenantId            String
  agentHubAgentId     String         @unique
  name                String
  slug                String
  phone               String?
  whatsapp            String?
  email               String?
  website             String?
  instagram           String?
  description         String?
  addressStreet       String?
  addressNumber       String?
  addressComplement   String?
  addressNeighborhood String?
  addressCity         String?
  addressState        String?
  addressZipcode      String?
  addressCountry      String?        @default("BR")
  latitude            Float?
  longitude           Float?
  timezone            String         @default("America/Sao_Paulo")
  currency            String         @default("BRL")
  locale              String         @default("pt-BR")
  operatingHours      Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  menuPdfUrl          String?
  dailyFeatures       DailyFeature[]
  employeeUnits       EmployeeUnit[]
  eventLogs           EventLog[]
  faqItems            FAQItem[]
  menuSections        MenuSection[]
  orders              Order[]
  requests            Request[]
  tables              Table[]
  tableSessions       TableSession[]
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Employee {
  id            String         @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String
  name          String
  role          EmployeeRole
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  authSessions  AuthSession[]
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeUnits EmployeeUnit[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model EmployeeUnit {
  employeeId String
  unitId     String
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  unit       Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([employeeId, unitId])
  @@index([unitId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  employeeId   String
  expires      DateTime
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model ApiClient {
  id               String    @id @default(cuid())
  tenantId         String
  clientId         String    @unique
  clientSecretHash String
  name             String
  scopes           String    @default("od.all")
  isActive         Boolean   @default(true)
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model MenuSection {
  id          String         @id @default(cuid())
  unitId      String
  name        String
  sortOrder   Int            @default(0)
  isAvailable Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  categories  MenuCategory[]
  unit        Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, name])
  @@index([unitId])
}

model MenuCategory {
  id                String            @id @default(cuid())
  sectionId         String
  name              String
  sortOrder         Int               @default(0)
  isAvailable       Boolean           @default(true)
  agentInstructions String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  section           MenuSection       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items             MenuItem[]
  subcategories     MenuSubcategory[]

  @@unique([sectionId, name])
  @@index([sectionId])
}

model MenuSubcategory {
  id          String       @id @default(cuid())
  categoryId  String
  name        String
  sortOrder   Int          @default(0)
  isAvailable Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  items       MenuItem[]
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@index([categoryId])
}

model MenuItem {
  id                String                @id @default(cuid())
  categoryId        String
  subcategoryId     String?
  name              String
  description       String?
  imageUrl          String?
  basePrice         Decimal               @db.Decimal(10, 2)
  isAvailable       Boolean               @default(true)
  sortOrder         Int                   @default(0)
  ean               String?
  agentInstructions String?
  portion           String?
  badges            String?
  constraints       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  category          MenuCategory          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory       MenuSubcategory?      @relation(fields: [subcategoryId], references: [id])
  optionGroups      MenuItemOptionGroup[]
  orderItems        OrderItem[]

  @@index([categoryId])
  @@index([subcategoryId])
}

model OptionGroup {
  id           String                @id @default(cuid())
  unitId       String
  name         String
  isMandatory  Boolean               @default(false)
  minSelection Int                   @default(0)
  maxSelection Int                   @default(1)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  items        MenuItemOptionGroup[]
  options      Option[]

  @@index([unitId])
}

model Option {
  id            String      @id @default(cuid())
  optionGroupId String
  name          String
  priceDelta    Decimal     @default(0) @db.Decimal(10, 2)
  isAvailable   Boolean     @default(true)
  sortOrder     Int         @default(0)
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  @@index([optionGroupId])
}

model MenuItemOptionGroup {
  menuItemId    String
  optionGroupId String
  sortOrder     Int         @default(0)
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  @@id([menuItemId, optionGroupId])
  @@index([optionGroupId])
}

model FAQItem {
  id          String   @id @default(cuid())
  unitId      String
  category    String
  question    String
  answer      String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([unitId, category])
}

model DailyFeature {
  id          String   @id @default(cuid())
  unitId      String
  date        DateTime @db.Date
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, date])
  @@index([unitId])
}

model Table {
  id        String         @id @default(cuid())
  unitId    String
  number    String
  label     String?
  status    TableStatus    @default(AVAILABLE)
  qrToken   String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  unit      Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  sessions  TableSession[]

  @@unique([unitId, number])
  @@index([unitId])
}

model TableSession {
  id                     String             @id @default(cuid())
  unitId                 String
  tableId                String
  agentHubConversationId String?
  customerPhone          String?
  status                 TableSessionStatus @default(ACTIVE)
  startedAt              DateTime           @default(now())
  endedAt                DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  orders                 Order[]
  requests               Request[]
  table                  Table              @relation(fields: [tableId], references: [id], onDelete: Cascade)
  unit                   Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, status])
  @@index([tableId, status])
  @@index([agentHubConversationId])
}

model Order {
  id                     String        @id @default(cuid())
  unitId                 String
  tableSessionId         String?
  agentHubConversationId String?
  agentHubMessageId      String?
  idempotencyKey         String?
  status                 OrderStatus   @default(CREATED)
  subtotal               Decimal       @db.Decimal(10, 2)
  total                  Decimal       @db.Decimal(10, 2)
  notes                  String?
  cancellationReason     String?
  createdAt              DateTime      @default(now())
  confirmedAt            DateTime?
  preparingAt            DateTime?
  concludedAt            DateTime?
  cancelledAt            DateTime?
  updatedAt              DateTime      @updatedAt
  tableSession           TableSession? @relation(fields: [tableSessionId], references: [id])
  unit                   Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  items                  OrderItem[]

  @@unique([unitId, idempotencyKey])
  @@index([unitId, status])
  @@index([tableSessionId])
  @@index([agentHubConversationId])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  menuItemId      String
  itemName        String
  quantity        Int      @default(1)
  unitPrice       Decimal  @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)
  observations    String?
  selectedOptions Json?
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId])
}

model Request {
  id                     String        @id @default(cuid())
  unitId                 String
  tableSessionId         String?
  agentHubConversationId String?
  agentHubMessageId      String?
  idempotencyKey         String?
  type                   RequestType
  description            String
  status                 RequestStatus @default(OPEN)
  assignedToEmployeeId   String?
  resolvedByEmployeeId   String?
  resolutionNotes        String?
  createdAt              DateTime      @default(now())
  acknowledgedAt         DateTime?
  resolvedAt             DateTime?
  updatedAt              DateTime      @updatedAt
  tableSession           TableSession? @relation(fields: [tableSessionId], references: [id])
  unit                   Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, idempotencyKey])
  @@index([unitId, status])
  @@index([tableSessionId])
  @@index([agentHubConversationId])
}

model EventLog {
  id         String       @id @default(cuid())
  unitId     String
  type       EventLogType
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime     @default(now())
  unit       Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, createdAt])
  @@index([unitId, type, createdAt])
  @@index([entityType, entityId])
}

enum EmployeeRole {
  ADMIN
  OPERATOR
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  DISABLED
}

enum TableSessionStatus {
  ACTIVE
  CLOSED
  ABANDONED
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PREPARING
  CONCLUDED
  CANCELLED
}

enum RequestType {
  ORDER
  CALL_WAITER
  PHYSICAL_MENU
  CHECK
  COMPLAINT
  ORDER_CHANGE
  ORDER_STATUS
  ORDER_CANCEL
  ALLERGY_INFO
  CUSTOM_ITEM
  OTHER
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum EventLogType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_CONCLUDED
  ORDER_CANCELLED
  REQUEST_CREATED
  REQUEST_ACKNOWLEDGED
  REQUEST_RESOLVED
  REQUEST_DISMISSED
  TABLE_OCCUPIED
  TABLE_RELEASED
  MENU_UPDATED
  DAILY_FEATURE_UPDATED
}
